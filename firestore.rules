rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if the user is an admin or super_admin
    // Checks custom claims first, then falls back to checking the role on their user document
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.role in ['admin', 'super_admin'] ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin']
      );
    }
    
    // DEFAULT DENY: Deny all reads and writes unless explicitly allowed below
    match /{document=**} {
      allow read, write: if false;
    }
    
    // USERS COLLECTION
    match /users/{userId} {
      // A user can read/write their own document
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      // Admins can read/write any user document
      allow read, write: if isAdmin();
    }
    
    // APPS COLLECTION (Public readable listings)
    match /apps/{appId} {
      // Anyone can read the apps
      allow read: if true;
      // Only admins can write/update apps
      allow write: if isAdmin();
    }
    
    // REVIEWS COLLECTION
    match /reviews/{reviewId} {
      // Anyone can read reviews
      allow read: if true;
      // Users can create/update their own reviews
      allow create, update: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Admins can do everything
      allow write: if isAdmin();
    }
  }
}
